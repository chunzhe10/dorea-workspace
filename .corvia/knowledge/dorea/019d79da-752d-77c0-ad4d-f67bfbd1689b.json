  "content": "fn cut_linear() -> f64 {\n    (10_f64.powf((CUT_ENCODED - D) / C) - B) / A\n}\nfn slope() -> f64 {\n    let cl = cut_linear();\n    C * A / ((A * cl + B) * 10_f64.ln())\n}\nfn intercept() -> f64 {\n    CUT_ENCODED - slope() * cut_linear()\n}",
