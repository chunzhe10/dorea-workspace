  "content": "def _tensor_to_pil(t: torch.Tensor) -> Image.Image:\n    \"\"\"(1, 3, H, W) or (3, H, W) fp32 [0,1] → PIL RGB Image.\"\"\"\n    if t.dim() == 4:\n        t = t[0]\n    arr = (t.permute(1, 2, 0).clamp(0, 1).cpu().numpy() * 255).astype(np.uint8)\n    return Image.fromarray(arr)",
