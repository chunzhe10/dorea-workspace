  "content": " let n = luts.len();\n        let zone_centers = (0..n)\n            .map(|i| (zone_boundaries[i] + zone_boundaries[i + 1]) / 2.0)\n            .collect();\n        Self {\n            luts,\n            zone_boundaries,\n            zone_centers,\n        }\n    }\npub fn n_zones(&self) -> usize {\n        self.luts.len()\n    }",
