  "content": "def _file_sha1_prefix(path: Path, length: int = 16) -> str:\n    h = hashlib.sha1()\n    with path.open(\"rb\") as f:\n        while True:\n            chunk = f.read(1024 * 1024)\n            if not chunk:\n                break\n            h.update(chunk)\n    return h.hexdigest()[:length]",
