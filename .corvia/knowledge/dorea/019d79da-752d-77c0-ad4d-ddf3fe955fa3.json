  "content": "pub struct Frame16 {\n    pub index: u64,\n    pub pixels: Vec<u16>, // RGB48: width * height * 3\n    pub width: usize,\n    pub height: usize,\n}\nimpl Frame16 {\n    /// Down-convert to 8-bit by keeping the high byte of each u16.\n    pub fn to_8bit(&self) -> Vec<u8> {\n        self.pixels.iter().map(|&v| (v >> 8) as u8).collect()\n    }\n}",
