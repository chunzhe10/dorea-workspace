  "content": "def probe(p):\n    r = subprocess.run([\"ffprobe\",\"-v\",\"quiet\",\"-print_format\",\"json\",\"-show_streams\",p], capture_output=True, text=True)\n    vs = [s for s in json.loads(r.stdout)[\"streams\"] if s[\"codec_type\"]==\"video\"][0]\n    return int(vs[\"width\"]), int(vs[\"height\"])",
