  "content": "pub fn scene_change_threshold() -> f32 {\n    std::env::var(\"DOREA_SCENE_THRESHOLD\")\n        .ok()\n        .and_then(|s| s.parse().ok())\n        .unwrap_or(0.15)\n}\npub fn is_scene_change(a: &[u8], b: &[u8]) -> bool {\n    histogram_distance(a, b) > scene_change_threshold()\n}",
