  "content": "def register(name: str) -> Callable:\n    \"\"\"Decorator: register an upscale method under ``name``.\"\"\"\n    def decorator(fn: Callable) -> Callable:\n        if name in REGISTRY:\n            raise ValueError(f\"method {name!r} already registered\")\n        REGISTRY[name] = fn\n        return fn\n    return decorator",
