  "content": "fn drop(&mut self) {\n        if let Some(ref p) = self.0 {\n            let _ = std::fs::remove_file(p);\n        }\n    }\nfn lerp_depth(a: &[f32], b: &[f32], t: f32) -> Vec<f32> {\n    let t = t.clamp(0.0, 1.0);\n    a.iter().zip(b.iter())\n        .map(|(&va, &vb)| va + (vb - va) * t)\n        .collect()\n}",
