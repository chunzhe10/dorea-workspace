  "content": "fn srgb_to_linear(v: f32) -> f32 {\n    if v <= 0.04045 {\n        v / 12.92\n    } else {\n        ((v + 0.055) / 1.055).powf(2.4)\n    }\n}\nfn linear_to_srgb(v: f32) -> f32 {\n    if v <= 0.003_130_8 {\n        v * 12.92\n    } else {\n        1.055 * v.powf(1.0 / 2.4) - 0.055\n    }\n}",
