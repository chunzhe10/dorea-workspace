  "content": "fn f_lab(t: f32) -> f32 {\n    if t > DELTA_CUBED {\n        t.cbrt()\n    } else {\n        t / DELTA_SQ_3 + 4.0 / 29.0\n    }\n}\nfn f_lab_inv(s: f32) -> f32 {\n    let delta = 6.0_f32 / 29.0;\n    if s > delta {\n        s * s * s\n    } else {\n        DELTA_SQ_3 * (s - 4.0 / 29.0)\n    }\n}",
