  "content": " fn map_cudarc_error(e: cudarc::driver::result::DriverError) -> GpuError {\n    let msg = format!(\"{e}\");\n    if msg.contains(\"OUT_OF_MEMORY\") || msg.contains(\"out of memory\") {\n        GpuError::Oom(msg)\n    } else {\n        GpuError::CudaFail(msg)\n    }\n}\nfn div_ceil(a: u32, b: u32) -> u32 {\n    a.div_ceil(b)\n}",
