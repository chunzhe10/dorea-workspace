  "content": "pub fn ilog_to_linear(x: f32) -> f32 {\n    let x = x as f64;\n    let linear = if x >= ENC_CUT {\n        10_f64.powf((x - D) / A) * 0.19 - B\n    } else {\n        (x - LIN_OFFSET) / LIN_SLOPE\n    };\n    linear.max(0.0) as f32\n}",
