  "content": "fn linear_to_srgb(v: f32) -> f32 {\n    if v <= 0.003_130_8 {\n        v * 12.92\n    } else {\n        1.055 * v.powf(1.0 / 2.4) - 0.055\n    }\n}\nfn f_lab(t: f32) -> f32 {\n    if t > DELTA_CUBED {\n        t.cbrt()\n    } else {\n        t / DELTA_SQ_3 + 4.0 / 29.0\n    }\n}",
