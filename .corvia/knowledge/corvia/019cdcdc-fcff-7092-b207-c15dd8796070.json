{
  "id": "019cdcdc-fcff-7092-b207-c15dd8796070",
  "content": "lx::query(\"DELETE FROM edges WHERE from_id = $1 OR to_id = $1\")\n            .bind(entry_id)\n            .execute(&self.pool)\n            .await\n            .map_err(|e| CorviaError::Storage(format!(\"Failed to remove edges: {e}\")))?;\n\n        Ok(())\n    }\n}\nasync fn relate(\n        &self,\n        from: &Uuid,\n        relation: &str,\n        to: &Uuid,\n        metadata: Option<serde_json::Value>,\n    ) -> Result<()> {\n        sqlx::query(\n            \"INSERT INTO edges (from_id, relation, to_id, metadata) \\\n             VALUES ($1, $2, $3, $4) ON CONFLICT DO NOTHING\",\n        )\n        .bind(from)\n        .bind(relation)\n        .bind(to)\n        .bind(&metadata)\n        .execute(&self.pool)\n        .await\n        .map_err(|e| CorviaError::Storage(format!(\"Failed to create edge: {e}\")))?;\n\n        Ok(())\n    }",
