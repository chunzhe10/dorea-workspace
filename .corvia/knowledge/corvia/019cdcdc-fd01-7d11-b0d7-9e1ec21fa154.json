{
  "id": "019cdcdc-fd01-7d11-b0d7-9e1ec21fa154",
  "content": "  .map_err(|e| CorviaError::Storage(e.to_string()))?;\n            let mut scope_table = write_txn.open_table(SCOPE_INDEX)\n                .map_err(|e| CorviaError::Storage(e.to_string()))?;\n            let mut u2h_table = write_txn.open_table(UUID_TO_HNSW)\n                .map_err(|e| CorviaError::Storage(e.to_string()))?;\n            let mut h2u_table = write_txn.open_table(HNSW_TO_UUID)\n                .map_err(|e| CorviaError::Storage(e.to_string()))?;\n\n            for uuid_str in &uuids_to_delete {\n                entries_table.remove(uuid_str.as_str()).ok();\n                let scope_key = format!(\"{scope_id}:{uuid_str}\");\n                scope_table.remove(scope_key.as_str()).ok();\n                if let Ok(Some(hnsw_id_guard)) = u2h_table.remove(uuid_str.as_str()) {\n                    h2u_table.remove(hnsw_id_guard.value()).ok();\n                }\n            }\n        }\n        write_txn.commit()\n            .map_err(|e| CorviaError::Storage(e.to_string()))?;\n\n        // Delete knowledge files for this scope\n        crate::knowledge_files::delete_scope_files(&self.data_dir, scope_id)?;\n\n        info!(\"Deleted {} entries for scope '{scope_id}'\", uuids_to_delete.len());\n        Ok(())\n    }\n}\n```\n",
