  "content": "pub fn parse_local_overrides(locals: &[String]) -> Result<Vec<(String, String)>> {\n    locals\n        .iter()\n        .map(|s| {\n            let (name, path) = s\n                .split_once('=')\n                .with_context(|| format!(\"Invalid local override '{s}': expected name=path\"))?;\n            Ok((name.to_string(), path.to_string()))\n        })\n        .collect()\n}",
