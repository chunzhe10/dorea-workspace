{
  "id": "019ca9e0-0085-7ec3-81d6-83e5d8391bc0",
  "content": "async fn get(&self, id: &uuid::Uuid) -> Result<Option<KnowledgeEntry>> {\n        let id_str = id.to_string();\n        let mut response = self\n            .db\n            .query(\"SELECT * FROM type::record('knowledge', $id);\")\n            .bind((\"id\", id_str))\n            .await\n            .map_err(|e| CorviaError::Storage(format!(\"Failed to get entry: {e}\")))?;\n\n        let result: Option<serde_json::Value> = response\n            .take(0)\n            .map_err(|e| CorviaError::Storage(format!(\"Failed to parse get result: {e}\")))?;\n\n        Ok(result.and_then(json_to_entry))\n    }",
