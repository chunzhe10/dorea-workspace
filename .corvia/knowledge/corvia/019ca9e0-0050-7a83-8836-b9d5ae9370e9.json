{
  "id": "019ca9e0-0050-7a83-8836-b9d5ae9370e9",
  "content": "async fn cmd_serve(mcp: bool) -> Result<()> {\n    let config = load_config()?;\n    let store: Arc<dyn QueryableStore> = Arc::from(connect_store(&config).await?);\n    let engine: Arc<dyn InferenceEngine> = Arc::from(connect_engine(&config));\n\n    // Construct AgentCoordinator\n    let data_dir = std::path::Path::new(&config.storage.data_dir);\n    let coordinator = match AgentCoordinator::new(\n        store.clone(),\n        engine.clone(),\n        data_dir,\n        config.agent_lifecycle.clone(),\n        config.merge.clone(),\n        config.embedding.url.clone(),\n    ) {\n        Ok(c) => {\n            println!(\"Agent coordination: enabled\");\n            Some(Arc::new(c))\n        }\n        Err(e) => {\n            println!(\"Agent coordination: disabled ({e})\");\n            None\n        }\n    };\n\n    let state = Arc::new(corvia_server::rest::AppState { store, engine, coordinator });\n    let mut app = corvia_server::rest::router(state.clone());\n\n    if mcp {\n        app = app.merge(corvia_server::mcp::mcp_router(state));\n        println!(\"MCP endpoint: POST /mcp\");\n    }\n\n    let addr = format!(\"{}:{}\", config.server.host, config.server.port);\n    println!(\"Corvia server listening on {addr}\");\n    let listener = tokio::net::TcpListener::bind(&addr).await?;\n    axum::serve(listener, app).await?;\n    Ok(())\n}",
