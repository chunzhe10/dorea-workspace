  "id": "019cdcdc-fd01-7d11-b0d7-b62243dfbd7b",
  "content": "### ChunkingStrategy\n### TokenEstimator\n\n## Core Types\n\n```rust\n/// Metadata about the source file being chunked\npub struct SourceMetadata {\n    pub file_path: String,\n    pub extension: String,\n    pub language: Option<String>,\n    pub scope_id: String,\n    pub source_version: String,\n}\n\n/// Raw chunk produced by a ChunkingStrategy (pre-budget, pre-merge)\npub struct RawChunk {\n    pub content: String,\n    pub chunk_type: String,             // \"function_item\", \"heading_section\", \"key_value\", \"file\"\n    pub start_line: u32,\n    pub end_line: u32,\n    pub metadata: ChunkMetadata,\n}\n\n/// Additional chunk metadata for provenance and graph linking\npub struct ChunkMetadata {\n    pub source_file: String,\n    pub language: Option<String>,\n    pub parent_chunk_id: Option<Uuid>,  // for split chunks — links back to original\n    pub merge_group: Option<String>,    // hint for which chunks can merge\n}\n\n/// Final chunk after pipeline processing — ready for embedding\npub struct ProcessedChunk {\n    pub content: String,                // may include overlap prefix\n    pub original_content: String,       // without overlap (for display/citation)\n    pub chunk_type: String,\n    pub start_line: u32,\n    pub end_line: u32,\n    pub metadata: ChunkMetadata,\n    pub token_estimate: usize,\n    pub processing: ProcessingInfo,\n}\n\n/// How this chunk was processed by the pipeline\npub struct ProcessingInfo {\n    pub strategy_name: String,\n    pub was_split: bool,\n    pub was_merged: bool,\n    pub overlap_tokens: usize,\n}\n\n/// Raw source file returned by IngestionAdapter\npub struct SourceFile {\n    pub content: String,\n    pub metadata: SourceMetadata,\n}\n```\n",
  "source_version": "docs/rfcs/2026-03-02-m3.3-embedding-chunking-design.md",
