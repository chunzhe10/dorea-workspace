  "content": "erde_json::from_slice(value.value())\n                .ok()\n                .and_then(|v: serde_json::Value| if v.is_null() { None } else { Some(v) });\n\n            edges.push(GraphEdge { from, to, relation, metadata });\n        }\n\n        Ok(edges)\n    }\n}\npub fn new(db: Arc<Database>) -> Result<Self> {\n        let store = Self {\n            db,\n            graph: Mutex::new(DiGraph::new()),\n            node_map: Mutex::new(HashMap::new()),\n        };\n        store.rebuild_from_redb()?;\n        Ok(store)\n    }",
