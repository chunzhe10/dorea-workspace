  "content": "pub fn touch(&self, agent_id: &str) -> Result<()> {\n        let mut record = self.get(agent_id)?\n            .ok_or_else(|| CorviaError::NotFound(format!(\"Agent {agent_id} not found\")))?;\n        record.last_seen = chrono::Utc::now();\n        self.put(&record)\n    }",
