  "content": "rocessing: ProcessingInfo {\n                    strategy_name: \"test\".into(),\n                    was_split: false,\n                    was_merged: false,\n                    overlap_tokens: 0,\n                },\n            },\n            ProcessedChunk {\n                content: \"fn use_string(s: String) {}\".into(),\n                chunk_type: \"function_item\".into(),\n                start_line: 1,\n                end_line: 1,\n                metadata: ChunkMetadata {\n                    source_file: \"src/other.rs\".into(),\n                    ..Default::default()\n                },\n                token_estimate: 8,\n                processing: ProcessingInfo {\n                    strategy_name: \"test\".into(),\n                    was_split: false,\n                    was_merged: false,\n                    overlap_tokens: 0,\n                },\n            },\n        ];\n\n        let relations = ChunkingPipeline::discover_cross_file_relations(&chunks);\n        assert!(relations.is_empty(), \"Should skip standard library type names\");\n    }\n\n    #[test]\n    fn test_word_boundary_matching() {\n        assert!(ChunkingPipeline::content_references_symbol(\"impl QueryableStore for Foo\", \"QueryableStore\"));\n        assert!(!ChunkingPipeline::content_references_symbol(\"impl NotQueryableStoreButSimilar\", \"QueryableStore\"));\n        assert!(ChunkingPipeline::content_references_symbol(\"use LiteStore;\", \"LiteStore\"));\n        assert!(!ChunkingPipeline::content_references_symbol(\"use LiteStoreExtra;\", \"LiteStore\"));\n    }\n```\n\n**Step 4: Run tests**\n\nRun: `cargo test -p corvia-kernel chunking_pipeline`\nExpected: All existing + 4 new tests pass.\n\n**Step 5: Commit**\n\n```bash\ngit add -A && git commit -m \"feat(m3.4): add discover_cross_file_relations for declaration→usage tracking (D74)\"\n```\n\n---\n",
