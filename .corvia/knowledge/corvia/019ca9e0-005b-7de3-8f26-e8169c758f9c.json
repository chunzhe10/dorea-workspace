{
  "id": "019ca9e0-005b-7de3-8f26-e8169c758f9c",
  "content": "pub fn find_stale(&self, timeout: std::time::Duration) -> Result<Vec<SessionRecord>> {\n        let cutoff = chrono::Utc::now() - chrono::Duration::from_std(timeout)\n            .unwrap_or(chrono::Duration::zero());\n        Ok(self.list_all()?\n            .into_iter()\n            .filter(|s| s.state == SessionState::Active && s.last_heartbeat < cutoff)\n            .collect())\n    }",
