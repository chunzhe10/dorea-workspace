{
  "id": "019ca9e0-0060-77c0-870b-72cd3791a687",
  "content": "pub async fn is_ollama_running(&self) -> Result<bool> {\n        let filters: HashMap<String, Vec<String>> = HashMap::from([\n            (\"name\".into(), vec![OLLAMA_CONTAINER_NAME.into()]),\n        ]);\n        let options = ListContainersOptions {\n            filters,\n            ..Default::default()\n        };\n        let containers = self.docker.list_containers(Some(options)).await\n            .map_err(|e| CorviaError::Docker(format!(\"Ollama: Failed to list containers: {e}\")))?;\n        Ok(!containers.is_empty())\n    }",
