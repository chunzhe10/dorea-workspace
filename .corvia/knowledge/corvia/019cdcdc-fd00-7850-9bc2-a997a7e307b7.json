{
  "id": "019cdcdc-fd00-7850-9bc2-a997a7e307b7",
  "content": "   }\n\n    #[test]\n    fn test_process_batch() {\n        let pipeline = make_pipeline(default_config());\n        let files = vec![\n            SourceFile {\n                content: \"File one content here.\".into(),\n                metadata: test_meta(\"txt\"),\n            },\n            SourceFile {\n                content: \"File two content here.\".into(),\n                metadata: SourceMetadata {\n                    file_path: \"other.txt\".into(),\n                    extension: \"txt\".into(),\n                    language: None,\n                    scope_id: \"test\".into(),\n                    source_version: \"v1\".into(),\n                },\n            },\n        ];\n        let (chunks, report) = pipeline.process_batch(&files).unwrap();\n        assert!(!chunks.is_empty());\n        assert_eq!(report.files_processed, 2);\n        assert!(report.total_chunks >= 2);\n    }\n\n    #[test]\n    fn test_process_overlap_context() {\n        let config = ChunkingConfig {\n            max_tokens: 10, // force splitting\n            min_tokens: 2,\n            overlap_tokens: 2, // 2 tokens = ~8 chars overlap\n            strategy: \"auto\".into(),\n        };\n        let pipeline = make_pipeline(config);\n        let source = \"First paragraph with some content.\\n\\nSecond paragraph with more content.\\n\\nThird paragraph with final content.\";\n        let chunks = pipeline.process(source, &test_meta(\"txt\")).unwrap();\n        if chunks.len() >= 2 {\n            // Second chunk onward should have overlap applied\n            let has_overlap = chunks.iter().skip(1).any(|c| c.processing.overlap_tokens > 0);\n            assert!(has_overlap, \"expected overlap context on subsequent chunks\");\n        }\n    }\n\n    #[test]\n    fn test_process_sets_processing_info() {\n        let pipeline = make_pipeline(default_config());\n        let chunks = pipeline.process(\"Some text content.\", &test_meta(\"txt\")).unwrap();\n        assert_eq!(chunks[0].processing.strategy_name, \"fallback\");\n        assert!(!chunks[0].processing.was_split);\n        assert!(!chunks[0].processing.was_merged);",
