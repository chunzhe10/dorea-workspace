  "content": "unk(source, &meta()).unwrap();\n        assert!(chunks.len() >= 2, \"should split on line boundaries\");\n    }\n\n    #[test]\n    fn test_empty_source() {\n        let chunker = FallbackChunker::new(512);\n        let chunks = chunker.chunk(\"\", &meta()).unwrap();\n        assert!(chunks.is_empty() || chunks.len() == 1);\n    }\n\n    #[test]\n    fn test_metadata_populated() {\n        let chunker = FallbackChunker::new(512);\n        let chunks = chunker.chunk(\"content here\\nmore content\", &meta()).unwrap();\n        assert!(!chunks.is_empty());\n        assert_eq!(chunks[0].metadata.source_file, \"readme.txt\");\n    }\n\n    #[test]\n    fn test_name_and_extensions() {\n        let chunker = FallbackChunker::new(512);\n        assert_eq!(chunker.name(), \"fallback\");\n        assert!(chunker.supported_extensions().is_empty());\n    }\n}\n```\n\n**Step 2: Register the module and run tests to verify they fail**\n\nAdd to `crates/corvia-kernel/src/lib.rs` after line 84 (`pub mod chunking_strategy;`):\n```rust\npub mod chunking_fallback;\n```\n\nRun: `cargo test -p corvia-kernel chunking_fallback -- --nocapture`\nExpected: FAIL (todo!() panics)\n\n**Step 3: Implement FallbackChunker**",
