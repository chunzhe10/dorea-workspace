  "content": "fn test_effective_min_score_fallback() {\n        let q = CanonicalQuery {\n            text: \"test\".into(),\n            expect_file: \"test.rs\".into(),\n            min_score: None,\n        };\n        assert_eq!(q.effective_min_score(0.70), 0.70);\n\n        let q2 = CanonicalQuery {\n            text: \"test\".into(),\n            expect_file: \"test.rs\".into(),\n            min_score: Some(0.80),\n        };\n        assert_eq!(q2.effective_min_score(0.70), 0.80);\n    }",
