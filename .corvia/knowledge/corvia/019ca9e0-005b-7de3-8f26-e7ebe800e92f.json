  "content": "pub fn increment_written(&self, session_id: &str) -> Result<()> {\n        let mut record = self.get(session_id)?\n            .ok_or_else(|| CorviaError::NotFound(format!(\"Session {session_id} not found\")))?;\n        record.entries_written += 1;\n        self.put(&record)\n    }",
