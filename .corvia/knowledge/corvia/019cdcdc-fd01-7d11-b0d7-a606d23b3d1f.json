  "id": "019cdcdc-fd01-7d11-b0d7-a606d23b3d1f",
  "content": ": Implement RagPipeline**\n\nAdd between the struct definition and `#[cfg(test)]`:\n\n```rust\nimpl RagPipeline {\n    pub fn new(\n        retriever: Arc<dyn Retriever>,\n        augmenter: Arc<dyn Augmenter>,\n        generator: Option<Arc<dyn GenerationEngine>>,\n        config: RagConfig,\n    ) -> Self {\n        Self { retriever, augmenter, generator, config }\n    }\n\n    /// Context-only mode: retrieve + augment, no generation.\n    pub async fn context(\n        &self,\n        query: &str,\n        scope_id: &str,\n        opts: Option<RetrievalOpts>,\n    ) -> Result<RagResponse> {\n        self.run_pipeline(query, scope_id, opts, false).await\n    }\n\n    /// Full RAG: retrieve + augment + generate.\n    pub async fn ask(\n        &self,\n        query: &str,\n        scope_id: &str,\n        opts: Option<RetrievalOpts>,\n    ) -> Result<RagResponse> {\n        let generator = self.generator.as_ref().ok_or_else(|| {\n            corvia_common::errors::CorviaError::Config(\n                \"GenerationEngine not configured — cannot use ask() mode\".into()\n            )\n        })?;\n        let _ = generator; // just validating it exists; run_pipeline uses self.generator\n        self.run_pipeline(query, scope_id, opts, true).await\n    }\n\n    async fn run_pipeline(\n        &self,\n        query: &str,\n        scope_id: &str,\n        opts: Option<RetrievalOpts>,\n        generate: bool,\n    ) -> Result<RagResponse> {\n        let pipeline_start = Instant::now();\n        let trace_id = Uuid::now_v7();\n\n        let mode = if generate { \"ask\" } else { \"context\" };",
  "source_version": "docs/rfcs/2026-03-02-m3.2-rag-pipeline-impl.md",
