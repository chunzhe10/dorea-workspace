{
  "id": "019cdcdc-fd01-7d11-b0d7-a5e29ea3a83f",
  "content": "mut next_emb = || { idx += 1; vec![1.0, idx as f32 * 0.001, 0.0] };\n\n        for i in 0..10 {\n            let mut e = KnowledgeEntry::new(\n                format!(\"knowledge entry {i}\"), \"proj\".into(), \"v1\".into(),\n            ).with_embedding(next_emb());\n            e.entry_status = EntryStatus::Merged;\n            store.insert(&e).await.unwrap();\n        }\n\n        let retriever = Arc::new(VectorRetriever::new(store, engine)) as Arc<dyn Retriever>;\n        let augmenter = Arc::new(StructuredAugmenter::new(None)) as Arc<dyn Augmenter>;\n        let generator: Option<Arc<dyn GenerationEngine>> = if with_generator {\n            Some(Arc::new(MockGenerator))\n        } else {\n            None\n        };\n\n        RagPipeline::new(retriever, augmenter, generator, RagConfig::default())\n    }\n\n    #[tokio::test]\n    async fn test_context_mode_returns_no_answer() {\n        let dir = tempfile::tempdir().unwrap();\n        let pipeline = setup_pipeline(dir.path(), false).await;\n\n        let response = pipeline.context(\"what is entry 0?\", \"proj\", None).await.unwrap();\n\n        assert!(response.answer.is_none());\n        assert!(!response.context.context.is_empty());\n        assert!(response.context.metrics.sources_included > 0);\n        assert!(response.trace.generation.is_none());\n        assert!(response.trace.total_latency_ms < 5000);\n        assert_eq!(response.trace.retrieval.retriever_name, \"vector\");\n        assert_eq!(response.trace.augmentation.augmenter_name, \"structured\");\n    }\n\n    #[tokio::test]\n    async fn test_ask_mode_returns_generated_answer() {\n        let dir = tempfile::tempdir().unwrap();\n        let pipeline = setup_pipeline(dir.path(), true).await;\n\n        let response = pipeline.ask(\"what is entry 0?\", \"proj\", None).await.unwrap();\n\n        assert!(response.answer.is_some());\n        let answer = response.answer.unwrap();\n        assert!(answer.contains(\"Generated answer for:\"));\n        assert!(response.trace.generation.is_some());",
