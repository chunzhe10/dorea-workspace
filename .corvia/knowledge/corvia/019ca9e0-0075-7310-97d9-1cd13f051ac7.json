{
  "id": "019ca9e0-0075-7310-97d9-1cd13f051ac7",
  "content": "fn is_git_repo(&self) -> bool {\n        // Walk up from data_dir looking for .git\n        let mut dir = self.data_dir.as_path();\n        loop {\n            if dir.join(\".git\").exists() {\n                return true;\n            }\n            match dir.parent() {\n                Some(parent) => dir = parent,\n                None => return false,\n            }\n        }\n    }",
