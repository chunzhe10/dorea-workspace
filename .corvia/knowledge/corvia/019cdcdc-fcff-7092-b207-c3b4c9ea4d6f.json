{
  "id": "019cdcdc-fcff-7092-b207-c3b4c9ea4d6f",
  "content": "ale: impl Into<String>,\n    ) -> Self {\n        Self {\n            check_type,\n            scope_id: scope_id.into(),\n            target_ids,\n            confidence,\n            rationale: rationale.into(),\n            found_at: Utc::now(),\n        }\n    }\npub fn to_knowledge_entry(&self) -> KnowledgeEntry {\n        let content = format!(\n            \"[{}] {}\\nTargets: {}\\nConfidence: {:.0}%\",\n            self.check_type.as_str(),\n            self.rationale,\n            self.target_ids\n                .iter()\n                .map(|id| id.to_string())\n                .collect::<Vec<_>>()\n                .join(\", \"),\n            self.confidence * 100.0,\n        );\n        let mut entry = KnowledgeEntry::new(\n            content,\n            self.scope_id.clone(),\n            \"reasoner\".to_string(),\n        );\n        entry.metadata.chunk_type = Some(\"finding\".to_string());\n        entry\n    }",
