{
  "id": "019ca9e0-0066-7450-b08e-a402a122aa90",
  "content": "pub fn set_status(&self, agent_id: &str, status: AgentStatus) -> Result<()> {\n        let mut record = self.get(agent_id)?\n            .ok_or_else(|| CorviaError::NotFound(format!(\"Agent {agent_id} not found\")))?;\n        record.status = status;\n        self.put(&record)\n    }",
