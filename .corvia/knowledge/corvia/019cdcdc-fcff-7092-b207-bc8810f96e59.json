  "content": "          None => return Ok(None),\n        };\n        let mut entries = Vec::new();\n        for id in ids {\n            if let Some(entry) = self.get(&id).await? {\n                entries.push(entry);\n            }\n        }\n        Ok(Some(entries))\n    }\nasync fn remove_edges(&self, entry_id: &uuid::Uuid) -> Result<()> {\n        self.graph.remove_edges(entry_id).await\n    }",
