{
  "id": "019cdcdc-fd00-7850-9bc2-6c4949b325dc",
  "content": "pub fn list_by_agent(&self, agent_id: &str) -> Result<Vec<SessionRecord>> {\n        Ok(self.list_all()?\n            .into_iter()\n            .filter(|s| s.agent_id == agent_id)\n            .collect())\n    }\npub fn find_stale(&self, timeout: std::time::Duration) -> Result<Vec<SessionRecord>> {\n        let cutoff = chrono::Utc::now() - chrono::Duration::from_std(timeout)\n            .unwrap_or(chrono::Duration::zero());\n        Ok(self.list_all()?\n            .into_iter()\n            .filter(|s| s.state == SessionState::Active && s.last_heartbeat < cutoff)\n            .collect())\n    }",
  "source_version": "crates/corvia-kernel/src/session_manager.rs",
