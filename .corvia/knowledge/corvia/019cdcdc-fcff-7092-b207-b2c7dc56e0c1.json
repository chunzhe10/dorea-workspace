{
  "id": "019cdcdc-fcff-7092-b207-b2c7dc56e0c1",
  "content": "fn set(&mut self, key: &str, value: String) {\n        if let Ok(name) = tonic::metadata::MetadataKey::from_bytes(key.as_bytes()) {\n            if let Ok(val) = value.parse() {\n                self.0.insert(name, val);\n            }\n        }\n    }\nimpl Extractor for MetadataExtractor<'_> {\n    fn get(&self, key: &str) -> Option<&str> {\n        self.0.get(key).and_then(|v| v.to_str().ok())\n    }\n\n    fn keys(&self) -> Vec<&str> {\n        self.0\n            .keys()\n            .filter_map(|k| match k {\n                tonic::metadata::KeyRef::Ascii(key) => Some(key.as_str()),\n                _ => None,\n            })\n            .collect()\n    }\n}",
  "source_version": "crates/corvia-telemetry/src/propagation.rs",
