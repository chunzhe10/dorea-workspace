  "content": "pub fn new(grpc_addr: &str) -> Self {\n        Self {\n            grpc_addr: grpc_addr.to_string(),\n        }\n    }\npub fn is_installed() -> bool {\n        std::process::Command::new(\"corvia-inference\")\n            .arg(\"--version\")\n            .stdout(std::process::Stdio::null())\n            .stderr(std::process::Stdio::null())\n            .status()\n            .map(|s| s.success())\n            .unwrap_or(false)\n    }",
