  "content": "    coordinator: &AgentCoordinator,\n    entry_ids: &[uuid::Uuid],\n) -> Result<usize> {\n    let mut retried = 0usize;\n    for id in entry_ids {\n        if coordinator.merge_queue.reset_retry(id)? {\n            retried += 1;\n        }\n    }\n    Ok(retried)\n}\npub fn adapters_list(extra_dirs: &[String]) -> Vec<DiscoveredAdapter> {\n    discover_adapters(extra_dirs)\n}",
