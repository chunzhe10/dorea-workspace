  "content": "ope_id != scope_id {\n                continue;\n            }\n\n            let score = 1.0 - distance; // cosine distance → similarity\n            results.push(SearchResult { entry, score });\n\n            if results.len() >= limit {\n                break;\n            }\n        }\n\n        Ok(results)\n    }\n\n    async fn get(&self, id: &uuid::Uuid) -> Result<Option<KnowledgeEntry>> {\n        let uuid_str = id.to_string();\n        let read_txn = self.db.begin_read()\n            .map_err(|e| CorviaError::Storage(format!(\"Redb read error: {e}\")))?;\n        let table = read_txn.open_table(ENTRIES)\n            .map_err(|e| CorviaError::Storage(e.to_string()))?;\n\n        match table.get(uuid_str.as_str()) {\n            Ok(Some(v)) => {\n                let entry: KnowledgeEntry = serde_json::from_slice(v.value())\n                    .map_err(|e| CorviaError::Storage(format!(\"Deserialize error: {e}\")))?;\n                Ok(Some(entry))\n            }\n            Ok(None) => Ok(None),\n            Err(e) => Err(CorviaError::Storage(format!(\"Redb get error: {e}\"))),\n        }\n    }\n\n    async fn count(&self, scope_id: &str) -> Result<u64> {\n        let prefix = format!(\"{scope_id}:\");\n        let prefix_end = format!(\"{scope_id};\"); // ';' is next ASCII char after ':'\n\n        let read_txn = self.db.begin_read()\n            .map_err(|e| CorviaError::Storage(format!(\"Redb read error: {e}\")))?;\n        let table = read_txn.open_table(SCOPE_INDEX)\n            .map_err(|e| CorviaError::Storage(e.to_string()))?;\n\n        let mut count = 0u64;\n        let range = table.range(prefix.as_str()..prefix_end.as_str())\n            .map_err(|e| CorviaError::Storage(e.to_string()))?;\n        for _ in range {\n            count += 1;\n        }\n\n        Ok(count)\n    }\n\n    async fn delete_scope(&self, scope_id: &str) -> Result<()> {\n        let prefix = format!(\"{scope_id}:\");\n        let prefix_end = format!(\"{scope_id};\");\n\n        // Collect UUIDs to delete",
