  "content": "pub fn avg_score(&self) -> f64 {\n        if self.results.is_empty() {\n            return 0.0;\n        }\n        let sum: f64 = self.results.iter().map(|r| r.score).sum();\n        sum / self.results.len() as f64\n    }",
