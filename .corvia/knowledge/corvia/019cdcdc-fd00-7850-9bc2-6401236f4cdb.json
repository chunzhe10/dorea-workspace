  "content": "pub fn new(url: &str) -> Self {\n        Self {\n            url: url.to_string(),\n        }\n    }\npub fn is_installed() -> bool {\n        std::process::Command::new(\"ollama\")\n            .arg(\"--version\")\n            .stdout(std::process::Stdio::null())\n            .stderr(std::process::Stdio::null())\n            .status()\n            .map(|s| s.success())\n            .unwrap_or(false)\n    }",
