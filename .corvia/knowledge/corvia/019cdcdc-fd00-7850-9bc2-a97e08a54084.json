  "content": "st]\n    fn test_registry_resolve_fallback() {\n        let fallback = Arc::new(FallbackChunker::new(512));\n        let registry = FormatRegistry::new(fallback);\n        let resolved = registry.resolve(\"xyz\");\n        assert_eq!(resolved.name(), \"fallback\");\n    }\n\n    #[test]\n    fn test_registry_default_takes_priority_over_fallback() {\n        let fallback = Arc::new(FallbackChunker::new(512));\n        let mut registry = FormatRegistry::new(fallback);\n        let md_strategy = Arc::new(FallbackChunker::new(256)); // pretend it's MarkdownChunker\n        registry.register_default(\"md\", md_strategy);\n        // \"md\" resolves to the registered default, not fallback\n        let resolved = registry.resolve(\"md\");\n        // both are FallbackChunker but we can check it resolves (not fallback max_tokens)\n        assert_eq!(resolved.name(), \"fallback\"); // same name — OK for now\n        // \"txt\" still falls back\n        assert_eq!(registry.resolve(\"txt\").name(), \"fallback\");\n    }\n\n    #[test]\n    fn test_registry_override_takes_priority_over_default() {\n        let fallback = Arc::new(FallbackChunker::new(512));\n        let mut registry = FormatRegistry::new(fallback);\n        registry.register_default(\"rs\", Arc::new(FallbackChunker::new(512)));\n        registry.register_override(\"rs\", Arc::new(FallbackChunker::new(256)));\n        // Override should be resolved\n        let resolved = registry.resolve(\"rs\");\n        assert_eq!(resolved.name(), \"fallback\");\n    }\n\n    // -- Pipeline tests --\n\n    #[test]\n    fn test_process_small_file() {\n        let pipeline = make_pipeline(default_config());\n        let source = \"Hello, world!\\nThis is a test file.\";\n        let chunks = pipeline.process(source, &test_meta(\"txt\")).unwrap();\n        assert!(!chunks.is_empty());\n        assert_eq!(chunks[0].processing.strategy_name, \"fallback\");\n        assert!(chunks[0].token_estimate > 0);\n    }\n\n    #[test]\n    fn test_process_enforces_token_budget() {\n        let config = ChunkingConfig {\n            max_tokens: 10, // ~40 chars",
