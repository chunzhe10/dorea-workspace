  "content": "impl AgentPermission {\n    pub fn can_write_scope(&self, scope_id: &str) -> bool {\n        match self {\n            Self::ReadOnly => false,\n            Self::ReadWrite { scopes } => scopes.iter().any(|s| s == scope_id || s == \"*\"),\n            Self::Admin => true,\n        }\n    }\n}",
