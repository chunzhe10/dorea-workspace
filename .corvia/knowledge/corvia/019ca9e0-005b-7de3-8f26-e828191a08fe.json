{
  "id": "019ca9e0-005b-7de3-8f26-e828191a08fe",
  "content": "pub fn find_orphaned(&self, grace: std::time::Duration) -> Result<Vec<SessionRecord>> {\n        let cutoff = chrono::Utc::now() - chrono::Duration::from_std(grace)\n            .unwrap_or(chrono::Duration::zero());\n        Ok(self.list_all()?\n            .into_iter()\n            .filter(|s| s.state == SessionState::Stale && s.last_heartbeat < cutoff)\n            .collect())\n    }",
