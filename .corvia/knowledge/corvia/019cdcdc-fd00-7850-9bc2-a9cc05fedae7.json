  "id": "019cdcdc-fd00-7850-9bc2-a9cc05fedae7",
  "content": "### Task 3: MarkdownChunker\n\n            file_path: \"README.md\".into(),\n            extension: \"md\".into(),\n            language: Some(\"markdown\".into()),\n            scope_id: \"test\".into(),\n            source_version: \"v1\".into(),\n        }\n    }\n\n    #[test]\n    fn test_splits_on_h1_headings() {\n        let source = \"# Introduction\\n\\nSome intro text.\\n\\n# Features\\n\\nFeature list here.\\n\";\n        let chunker = MarkdownChunker::new();\n        let chunks = chunker.chunk(source, &meta()).unwrap();\n        assert_eq!(chunks.len(), 2);\n        assert!(chunks[0].content.contains(\"# Introduction\"));\n        assert!(chunks[1].content.contains(\"# Features\"));\n    }\n\n    #[test]\n    fn test_splits_on_mixed_heading_levels() {\n        let source = \"# Top\\n\\nIntro.\\n\\n## Section A\\n\\nContent A.\\n\\n## Section B\\n\\nContent B.\\n\";\n        let chunker = MarkdownChunker::new();\n        let chunks = chunker.chunk(source, &meta()).unwrap();\n        assert!(chunks.len() >= 2, \"expected at least 2 chunks, got {}\", chunks.len());\n    }\n\n    #[test]\n    fn test_no_headings_returns_single_chunk() {\n        let source = \"Just some plain text without any headings.\\nAnother line.\";\n        let chunker = MarkdownChunker::new();\n        let chunks = chunker.chunk(source, &meta()).unwrap();\n        assert_eq!(chunks.len(), 1);\n        assert_eq!(chunks[0].chunk_type, \"text\");\n    }\n\n    #[test]\n    fn test_chunk_type_is_heading_section() {\n        let source = \"# Title\\n\\nBody text.\";\n        let chunker = MarkdownChunker::new();",
