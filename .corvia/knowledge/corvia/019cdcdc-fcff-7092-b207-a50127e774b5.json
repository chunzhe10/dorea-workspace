  "content": "fn validate_dir_name(name: &str) -> Result<()> {\n    if name.is_empty()\n        || name.contains('/')\n        || name.contains('\\\\')\n        || name.contains('\\0')\n        || name == \".\"\n        || name == \"..\"\n    {\n        anyhow::bail!(\n            \"Invalid name '{}': must not be empty, contain path separators, or be '.' or '..'\",\n            name\n        );\n    }\n    Ok(())\n}",
