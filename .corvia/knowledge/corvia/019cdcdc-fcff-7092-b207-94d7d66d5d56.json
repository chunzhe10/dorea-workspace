  "content": "fn is_confirmed(meta: Option<&Value>) -> bool {\n    meta.and_then(|m| m.get(\"confirmed\"))\n        .and_then(|v| v.as_bool())\n        .unwrap_or(false)\n}\nfn is_dry_run(args: &Value) -> bool {\n    args.get(\"dry_run\").and_then(|v| v.as_bool()).unwrap_or(false)\n}",
