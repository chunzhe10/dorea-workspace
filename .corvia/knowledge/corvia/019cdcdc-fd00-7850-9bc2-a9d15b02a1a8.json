  "id": "019cdcdc-fd00-7850-9bc2-a9d15b02a1a8",
  "content": ")).unwrap();\n        assert_eq!(chunks.len(), 1);\n        assert_eq!(chunks[0].chunk_type, \"text\");\n    }\n\n    #[test]\n    fn test_chunk_type_is_heading_section() {\n        let source = \"# Title\\n\\nBody text.\";\n        let chunker = MarkdownChunker::new();\n        let chunks = chunker.chunk(source, &meta()).unwrap();\n        assert_eq!(chunks[0].chunk_type, \"heading_section\");\n    }\n\n    #[test]\n    fn test_empty_source() {\n        let chunker = MarkdownChunker::new();\n        let chunks = chunker.chunk(\"\", &meta()).unwrap();\n        assert!(chunks.is_empty());\n    }\n\n    #[test]\n    fn test_overlap_carries_heading_hierarchy() {\n        let chunker = MarkdownChunker::new();\n        let prev = RawChunk {\n            content: \"## Auth\\n\\n### JWT\\n\\nJWT details.\".into(),\n            chunk_type: \"heading_section\".into(),\n            start_line: 1,\n            end_line: 5,\n            metadata: ChunkMetadata::default(),\n        };\n        let next = RawChunk {\n            content: \"### OAuth\\n\\nOAuth details.\".into(),\n            chunk_type: \"heading_section\".into(),\n            start_line: 6,\n            end_line: 8,\n            metadata: ChunkMetadata::default(),\n        };\n        let overlap = chunker.overlap_context(&prev, &next);\n        // Should carry heading hierarchy as context\n        assert!(overlap.is_some(), \"markdown overlap should carry heading context\");\n    }\n\n    #[test]\n    fn test_name_and_extensions() {\n        let chunker = MarkdownChunker::new();\n        assert_eq!(chunker.name(), \"markdown\");\n        assert_eq!(chunker.supported_extensions(), &[\"md\"]);\n    }",
