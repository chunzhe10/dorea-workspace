  "content": "pub fn cleanup_staging_dir(&self, staging_dir: &Path) -> Result<()> {\n        if staging_dir.exists() {\n            std::fs::remove_dir_all(staging_dir)\n                .map_err(|e| CorviaError::Agent(format!(\"Failed to cleanup staging dir: {e}\")))?;\n        }\n        Ok(())\n    }",
