  "content": "t {\n                query: query.to_string(),\n                scope_id: scope_id.to_string(),\n                limit: Some(limit),\n            })\n            .send()\n            .await?\n            .error_for_status()?;\n\n        Ok(resp.json().await?)\n    }\npub async fn reason(\n        &self,\n        scope_id: &str,\n        check: Option<&str>,\n    ) -> Result<ReasonResponse> {\n        let resp = self\n            .client\n            .post(format!(\"{}/v1/reason\", self.base_url))\n            .json(&ReasonRequest {\n                scope_id: scope_id.to_string(),\n                check: check.map(String::from),\n            })\n            .send()\n            .await?\n            .error_for_status()?;\n\n        Ok(resp.json().await?)\n    }",
