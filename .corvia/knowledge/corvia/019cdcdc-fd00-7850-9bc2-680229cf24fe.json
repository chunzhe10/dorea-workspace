{
  "id": "019cdcdc-fd00-7850-9bc2-680229cf24fe",
  "content": "            description,\n                    content,\n                    embedding,\n                }\n            })\n            .collect();\n\n        info!(count = skills.len(), \"skills loaded into registry\");\n        Ok(Self { skills, dimensions })\n    }\npub fn match_skills(\n        &self,\n        query_embedding: &[f32],\n        threshold: f32,\n        max_skills: usize,\n    ) -> Vec<SkillMatch<'_>> {\n        let mut matches: Vec<SkillMatch<'_>> = self\n            .skills\n            .iter()\n            .filter_map(|skill| {\n                let score = cosine_similarity(query_embedding, &skill.embedding);\n                if score >= threshold {\n                    Some(SkillMatch { skill, score })\n                } else {\n                    None\n                }\n            })\n            .collect();\n\n        // Sort by score descending.\n        matches.sort_by(|a, b| b.score.partial_cmp(&a.score).unwrap_or(std::cmp::Ordering::Equal));\n        matches.truncate(max_skills);\n        matches\n    }",
