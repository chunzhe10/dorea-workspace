  "content": ".entry_status = EntryStatus::Merged;\n            store.insert(&f).await.unwrap();\n        }\n\n        let retriever = VectorRetriever::new(store, engine);\n        let opts = RetrievalOpts {\n            limit: 10,\n            visibility: VisibilityMode::Own,\n            agent_id: Some(\"agent-A\".into()),\n            ..Default::default()\n        };\n        let result = retriever.retrieve(\"test\", \"proj\", &opts).await.unwrap();\n\n        // Should see merged + agent-A's pending, NOT agent-B's pending\n        let has_merged = result.results.iter().any(|r| r.entry.entry_status == EntryStatus::Merged);\n        let has_a = result.results.iter().any(|r| r.entry.agent_id.as_deref() == Some(\"agent-A\"));\n        let has_b = result.results.iter().any(|r| r.entry.agent_id.as_deref() == Some(\"agent-B\"));\n\n        assert!(has_merged);\n        assert!(has_a);\n        assert!(!has_b);\n    }\n}\n```\n\n**Step 2: Run tests to verify they fail**\n\nRun: `cargo test -p corvia-kernel -- retriever::tests --nocapture`\nExpected: FAIL — `VectorRetriever` not found\n\n**Step 3: Implement VectorRetriever**\n\nAdd above the `#[cfg(test)]` block in `retriever.rs`:\n\n```rust\n/// Pure vector search retriever. Baseline strategy.\n/// Embeds query → store.search() → RBAC filter → visibility filter.\npub struct VectorRetriever {\n    store: Arc<dyn QueryableStore>,\n    engine: Arc<dyn InferenceEngine>,\n}\n\nimpl VectorRetriever {\n    pub fn new(store: Arc<dyn QueryableStore>, engine: Arc<dyn InferenceEngine>) -> Self {\n        Self { store, engine }\n    }\n}\n",
