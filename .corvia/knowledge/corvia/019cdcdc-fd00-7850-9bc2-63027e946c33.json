  "content": " container: {e}\")))?;\n        self.docker.remove_container(CONTAINER_NAME, None::<bollard::container::RemoveContainerOptions>).await\n            .map_err(|e| CorviaError::Docker(format!(\"SurrealDB: Failed to remove container: {e}\")))?;\n        Ok(())\n    }\npub async fn is_vllm_running(&self) -> Result<bool> {\n        let filters: HashMap<String, Vec<String>> = HashMap::from([\n            (\"name\".into(), vec![VLLM_CONTAINER_NAME.into()]),\n        ]);\n        let options = ListContainersOptions {\n            filters,\n            ..Default::default()\n        };\n        let containers = self.docker.list_containers(Some(options)).await\n            .map_err(|e| CorviaError::Docker(format!(\"vLLM: Failed to list containers: {e}\")))?;\n        Ok(!containers.is_empty())\n    }",
