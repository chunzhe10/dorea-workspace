{
  "id": "019cdcdc-fd00-7850-9bc2-6048e2fb3d3d",
  "content": "fn test_reset_retry_nonexistent() {\n        let queue = test_queue();\n        let id = uuid::Uuid::now_v7();\n        assert!(!queue.reset_retry(&id).unwrap());\n    }\nfn test_queue_depth() {\n        let queue = test_queue();\n        for _ in 0..5 {\n            queue.enqueue(uuid::Uuid::now_v7(), \"a\", \"s\", \"scope\").unwrap();\n        }\n        assert_eq!(queue.depth().unwrap(), 5);\n    }",
