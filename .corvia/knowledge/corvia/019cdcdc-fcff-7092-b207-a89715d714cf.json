  "content": " relation {\n            url = format!(\"{}?relation={}\", url, rel);\n        }\n\n        let resp = self\n            .client\n            .get(&url)\n            .send()\n            .await?\n            .error_for_status()?;\n\n        Ok(resp.json().await?)\n    }\npub async fn evolution(\n        &self,\n        scope: &str,\n        since: &str,\n    ) -> Result<Vec<EvolutionEntryDto>> {\n        let url = format!(\n            \"{}/v1/evolution?scope={}&since={}\",\n            self.base_url, scope, since\n        );\n\n        let resp = self\n            .client\n            .get(&url)\n            .send()\n            .await?\n            .error_for_status()?;\n\n        Ok(resp.json().await?)\n    }",
