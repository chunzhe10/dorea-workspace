  "content": "or storage.\\n\";\n    let meta = SourceMetadata {\n        file_path: \"docs/types.md\".into(),\n        extension: \"md\".into(),\n        ..Default::default()\n    };\n    let chunker = MarkdownChunker::new();\n    let result = chunker.chunk(source, &meta).unwrap();\n    let names: Vec<_> = result.relations.iter().filter_map(|r| r.to_name.as_ref()).collect();\n    assert!(!names.contains(&&\"String\".to_string()), \"Should skip String\");\n    assert!(!names.contains(&&\"Vec\".to_string()), \"Should skip Vec\");\n    assert!(names.contains(&&\"QueryableStore\".to_string()), \"Should keep QueryableStore\");\n}\n\n#[test]\nfn test_skip_http_urls() {\n    let source = \"# Links\\n\\nSee [docs](https://example.com/foo.rs) for info.\\n\";\n    let meta = SourceMetadata {\n        file_path: \"docs/links.md\".into(),\n        extension: \"md\".into(),\n        ..Default::default()\n    };\n    let chunker = MarkdownChunker::new();\n    let result = chunker.chunk(source, &meta).unwrap();\n    let file_refs: Vec<_> = result.relations.iter().filter(|r| !r.to_file.is_empty()).collect();\n    assert!(file_refs.is_empty(), \"Should not extract HTTP URLs as file refs\");\n}\n```\n\n**Step 5: Run tests**\n\nRun: `cd /root/corvia-project/corvia-workspace/repos/corvia && cargo test -p corvia-kernel chunking_markdown`\nExpected: All existing + 4 new tests pass.\n\n**Step 6: Commit**\n\n```bash\ngit add -A && git commit -m \"feat(m3.4): extract markdown cross-references via pulldown-cmark (D73)\"\n```\n\n---\n",
