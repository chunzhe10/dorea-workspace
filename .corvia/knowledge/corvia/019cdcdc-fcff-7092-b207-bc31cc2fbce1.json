{
  "id": "019cdcdc-fcff-7092-b207-bc31cc2fbce1",
  "content": "entry_val)) = entries_table.get(entry_uuid_str) {\n                if let Ok(entry) = serde_json::from_slice::<KnowledgeEntry>(entry_val.value()) {\n                    results.push(entry);\n                }\n            }\n        }\n\n        Ok(results)\n    }\nimpl crate::traits::GraphStore for LiteStore {\n    async fn relate(\n        &self,\n        from: &uuid::Uuid,\n        relation: &str,\n        to: &uuid::Uuid,\n        metadata: Option<serde_json::Value>,\n    ) -> Result<()> {\n        self.graph.relate(from, relation, to, metadata).await\n    }\n\n    async fn edges(\n        &self,\n        entry_id: &uuid::Uuid,\n        direction: corvia_common::types::EdgeDirection,\n    ) -> Result<Vec<corvia_common::types::GraphEdge>> {\n        self.graph.edges(entry_id, direction).await\n    }\n\n    async fn traverse(\n        &self,\n        start: &uuid::Uuid,\n        relation: Option<&str>,\n        direction: corvia_common::types::EdgeDirection,\n        max_depth: usize,\n    ) -> Result<Vec<KnowledgeEntry>> {\n        let ids = self.graph.traverse_ids(start, relation, direction, max_depth)?;\n        let mut entries = Vec::new();\n        for id in ids {\n            if let Some(entry) = self.get(&id).await? {\n                entries.push(entry);\n            }\n        }\n        Ok(entries)\n    }\n\n    async fn shortest_path(\n        &self,\n        from: &uuid::Uuid,\n        to: &uuid::Uuid,\n    ) -> Result<Option<Vec<KnowledgeEntry>>> {\n        let ids = match self.graph.shortest_path_ids(from, to)? {\n            Some(ids) => ids,\n            None => return Ok(None),\n        };\n        let mut entries = Vec::new();\n        for id in ids {\n            if let Some(entry) = self.get(&id).await? {\n                entries.push(entry);\n            }\n        }\n        Ok(Some(entries))\n    }\n\n    async fn remove_edges(&self, entry_id: &uuid::Uuid) -> Result<()> {\n        self.graph.remove_edges(entry_id).await\n    }\n}",
