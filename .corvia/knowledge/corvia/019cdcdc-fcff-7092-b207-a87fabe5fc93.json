  "content": "           .json(&ReasonRequest {\n                scope_id: scope_id.to_string(),\n                check: check.map(String::from),\n            })\n            .send()\n            .await?\n            .error_for_status()?;\n\n        Ok(resp.json().await?)\n    }\npub async fn history(&self, entry_id: &str) -> Result<Vec<HistoryEntryDto>> {\n        let resp = self\n            .client\n            .get(format!(\"{}/v1/entries/{}/history\", self.base_url, entry_id))\n            .send()\n            .await?\n            .error_for_status()?;\n\n        Ok(resp.json().await?)\n    }",
