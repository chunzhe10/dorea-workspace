{
  "id": "019cdcdc-fd00-7850-9bc2-9fc3aad2f9f8",
  "content": "_declaration(\"use config;\"), None);\n    }\n\n    #[test]\n    fn test_build_single_crate() {\n        let dir = tempfile::tempdir().unwrap();\n        let root = dir.path();\n\n        // Create a mini crate\n        fs::write(\n            root.join(\"Cargo.toml\"),\n            \"[package]\\nname = \\\"my-crate\\\"\\nversion = \\\"0.1.0\\\"\\nedition = \\\"2021\\\"\\n\",\n        ).unwrap();\n        fs::create_dir_all(root.join(\"src\")).unwrap();\n        fs::write(root.join(\"src/lib.rs\"), \"mod config;\\nmod utils;\\n\").unwrap();\n        fs::write(root.join(\"src/config.rs\"), \"pub struct Config {}\\n\").unwrap();\n        fs::create_dir_all(root.join(\"src/utils\")).unwrap();\n        fs::write(root.join(\"src/utils/mod.rs\"), \"mod helpers;\\n\").unwrap();\n        fs::write(root.join(\"src/utils/helpers.rs\"), \"pub fn help() {}\\n\").unwrap();\n\n        let map = RustModuleMap::build(root);\n\n        assert_eq!(map.module_to_file.get(\"my_crate\"), Some(&\"src/lib.rs\".to_string()));\n        assert_eq!(map.module_to_file.get(\"my_crate::config\"), Some(&\"src/config.rs\".to_string()));\n        assert!(map.module_to_file.contains_key(\"my_crate::utils\"));\n        assert!(map.module_to_file.contains_key(\"my_crate::utils::helpers\"));\n    }\n\n    #[test]\n    fn test_build_workspace() {\n        let dir = tempfile::tempdir().unwrap();\n        let root = dir.path();\n\n        // Create workspace\n        fs::write(\n            root.join(\"Cargo.toml\"),\n            \"[workspace]\\nmembers = [\\\"crates/alpha\\\", \\\"crates/beta\\\"]\\n\",\n        ).unwrap();\n\n        // Crate alpha\n        fs::create_dir_all(root.join(\"crates/alpha/src\")).unwrap();",
