  "id": "019cdcdc-fd01-7d11-b0d7-9909591caed7",
  "content": "### Stage 3: GenerationEngine (D63)\n\n## Core Types\n\n```rust\npub struct RetrievalOpts {\n    pub limit: usize,                          // default 10\n    pub expand_graph: bool,                    // follow graph edges, default true\n    pub graph_depth: usize,                    // max hops, default 2\n    pub visibility: VisibilityMode,\n    pub agent_id: Option<String>,\n    pub permissions: Option<AgentPermission>,\n}\n\npub struct TokenBudget {\n    pub max_context_tokens: Option<usize>,     // None = model-aware auto-sizing\n    pub reserve_for_answer: f32,               // fraction reserved for generation, default 0.2\n}\n\npub struct RetrievalResult {\n    pub results: Vec<SearchResult>,\n    pub metrics: RetrievalMetrics,\n}\n\npub struct AugmentedContext {\n    pub system_prompt: String,\n    pub context: String,                       // formatted source text\n    pub sources: Vec<SearchResult>,            // entries included in context\n    pub metrics: AugmentationMetrics,\n}\n\npub struct GenerationResult {\n    pub text: String,\n    pub model: String,\n    pub input_tokens: usize,\n    pub output_tokens: usize,\n}\n\npub struct RagResponse {\n    pub answer: Option<String>,                // None for context-only mode\n    pub context: AugmentedContext,\n    pub trace: PipelineTrace,\n}\n```\n\n\n## RagPipeline\n\n```rust\npub struct RagPipeline {\n    retriever: Arc<dyn Retriever>,\n    augmenter: Arc<dyn Augmenter>,\n    generator: Option<Arc<dyn GenerationEngine>>,\n    config: RagConfig,\n}\n\nimpl RagPipeline {\n    /// Context-only mode: retrieve + augment, no generation.\n    pub async fn context(\n        &self,\n        query: &str,\n        scope_id: &str,\n        opts: Option<RetrievalOpts>,\n    ) -> Result<RagResponse>;\n\n    /// Full RAG: retrieve + augment + generate.\n    /// Returns error if GenerationEngine is not configured.\n    pub async fn ask(\n        &self,\n        query: &str,\n        scope_id: &str,\n        opts: Option<RetrievalOpts>,\n    ) -> Result<RagResponse>;\n}\n```\n",
