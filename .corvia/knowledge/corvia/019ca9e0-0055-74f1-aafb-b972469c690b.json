{
  "id": "019ca9e0-0055-74f1-aafb-b972469c690b",
  "content": "pub fn resolve_repo_path(workspace_root: &Path, repos_dir: &str, repo: &RepoConfig) -> PathBuf {\n    if let Some(local) = &repo.local {\n        let local_path = PathBuf::from(local);\n        if local_path.join(\".git\").exists() {\n            return local_path;\n        }\n    }\n    workspace_root.join(repos_dir).join(&repo.name)\n}",
