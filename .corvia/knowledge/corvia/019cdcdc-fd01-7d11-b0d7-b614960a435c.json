  "id": "019cdcdc-fd01-7d11-b0d7-b614960a435c",
  "content": "## Trait Definitions\n\n### ChunkingStrategy\n\n```rust\npub trait ChunkingStrategy: Send + Sync {\n    /// Identifier for metrics attribution and benchmarking.\n    fn name(&self) -> &str;\n\n    /// Supported file extensions this strategy handles.\n    fn supported_extensions(&self) -> &[&str];\n\n    /// Domain-specific: extract semantic boundaries from source.\n    /// Returns raw chunks WITHOUT embeddings.\n    fn chunk(\n        &self,\n        source: &str,\n        meta: &SourceMetadata,\n    ) -> Result<Vec<RawChunk>>;\n\n    /// Domain-specific: split an oversized chunk that exceeds token budget.\n    /// Called by kernel when a chunk violates the budget.\n    /// Default: split at character midpoint.\n    fn split_oversized(\n        &self,\n        chunk: &RawChunk,\n        max_tokens: usize,\n    ) -> Result<Vec<RawChunk>> {\n        // default: naive midpoint split\n    }\n\n    /// Domain-specific: merge small adjacent chunks up to budget.\n    /// Return None to use kernel's default merge pass.\n    /// Return Some(merged) to take full control.\n    fn merge_small(\n        &self,\n        chunks: &[RawChunk],\n        max_tokens: usize,\n    ) -> Option<Vec<RawChunk>> {\n        None\n    }\n\n    /// Domain-specific: what context to carry between adjacent chunks.\n    /// Default: no overlap.\n    fn overlap_context(\n        &self,\n        prev: &RawChunk,\n        next: &RawChunk,\n    ) -> Option<String> {\n        None\n    }\n}\n```\n\n\n### TokenEstimator\n\n```rust\npub trait TokenEstimator: Send + Sync {\n    fn estimate(&self, text: &str) -> usize;\n}\n\n/// Default: chars / 4 heuristic (shared with M3.2 D64)\npub struct CharDivFourEstimator;\n```\n\nPluggable — swap in tiktoken or sentencepiece later without changing the pipeline.\n",
