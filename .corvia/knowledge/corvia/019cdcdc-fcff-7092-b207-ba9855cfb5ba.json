  "content": "for LiteStore {\n    fn drop(&mut self) {\n        if let Err(e) = self.flush_hnsw() {\n            eprintln!(\"LiteStore: failed to flush HNSW on drop: {e}\");\n        } else {\n            eprintln!(\"LiteStore: HNSW index persisted to disk\");\n        }\n    }\n}\nfn drop(&mut self) {\n        if let Err(e) = self.flush_hnsw() {\n            eprintln!(\"LiteStore: failed to flush HNSW on drop: {e}\");\n        } else {\n            eprintln!(\"LiteStore: HNSW index persisted to disk\");\n        }\n    }",
