  "content": "\n            return false;\n        }\n        const EXTENSIONS: &[&str] = &[\n            \".rs\", \".ts\", \".tsx\", \".js\", \".jsx\", \".py\",\n            \".toml\", \".yaml\", \".yml\", \".json\", \".md\",\n        ];\n        EXTENSIONS.iter().any(|ext| s.ends_with(ext))\n    }\nfn find_chunk_for_line<'a>(chunks: &'a [RawChunk], line: u32) -> Option<&'a RawChunk> {\n        chunks\n            .iter()\n            .find(|c| line >= c.start_line && line <= c.end_line)\n            .or_else(|| chunks.last())\n    }",
