  "content": "rviaConfig::load(&config_path)?\n    } else {\n        let config = workspace::generate_workspace_config(&name, &repos, &local_overrides);\n        let root = PathBuf::from(&name);\n        workspace::scaffold_workspace(&root, &config)?;\n        config\n    };\n\n    let root = PathBuf::from(&name);\n    workspace::init_workspace(&root).await?;\n    println!(\"\\nWorkspace '{}' created at ./{}\", name, name);\n    if config.is_workspace() {\n        let ws = config.workspace.as_ref().unwrap();\n        for repo in &ws.repos {\n            println!(\"  repo: {} (namespace: {})\", repo.name, repo.namespace);\n        }\n    }\n    println!(\"\\nNext: cd {} && corvia workspace ingest\", name);\n    Ok(())\n}\n```\n\n**Step 4: Wire up the init handler**\n\nReplace `todo!()` in `WorkspaceCommands::Init`:\n\n```rust\nWorkspaceCommands::Init => {\n    let root = std::env::current_dir()?;\n    workspace::init_workspace(&root).await?;\n    Ok(())\n}\n```\n\n**Step 5: Verify it compiles**\n\nRun: `cargo build -p corvia-cli`\nExpected: compiles cleanly.\n\n**Step 6: Commit**\n\n```bash\ngit add crates/corvia-cli/src/main.rs crates/corvia-cli/src/workspace.rs crates/corvia-kernel/src/lib.rs\ngit commit -m \"feat(m2.1): implement corvia workspace create and init commands\"\n```\n\n---\n",
