{
  "id": "019ca9e0-0055-74f1-aafb-ba9a1b2a058f",
  "content": "fn test_add_repo_to_config() {\n        let mut config =\n            generate_workspace_config(\"test\", &[\"https://github.com/org/a\".into()], &[]);\n        add_repo_to_config(\n            &mut config,\n            \"https://github.com/org/b\",\n            Some(\"b\"),\n            Some(\"b-ns\"),\n            None,\n        )\n        .unwrap();\n        let ws = config.workspace.as_ref().unwrap();\n        assert_eq!(ws.repos.len(), 2);\n        assert_eq!(ws.repos[1].name, \"b\");\n        assert_eq!(ws.repos[1].namespace, \"b-ns\");\n    }",
